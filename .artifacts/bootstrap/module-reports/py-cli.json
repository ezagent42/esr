        "esr debug inject --to thread:foo --event '{\"event_type\":\"msg_received\",...}'",
        "esr debug resume thread:foo  → drains queued events",
        "esr trace --session thread:foo --last 5m  → Telemetry.Buffer ring"
      ]
    },
    {
      "flow": "Graceful shutdown",
      "steps": [
        "esr drain --timeout 30s  → cli:drain RPC; reports drained / timeouts; exit non-zero if any topology timed out"
      ]
    },
    {
      "flow": "E2E scenario execution",
      "steps": [
        "Author scenarios/<name>.yaml with setup/steps/teardown sections",
        "esr scenario run <name> [--verbose]  → runs each step as shell subprocess, matches expect_stdout_match regex, exit 0 iff every step passes"
      ]
    },
    {
      "flow": "Offline development (no runtime)",
      "steps": [
        "esr cmd compile feishu-app-session -o /tmp/x.yaml  (no network)",
        "esr lint handlers/feishu_app/src  (purity import scan)",
        "esr adapter list / handler list / cmd list  (read-only scans)"
      ]
    }
