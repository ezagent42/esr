    "runtime_bridge": {
      "description": "Synchronous Phoenix-channel RPC — each `cli:<op>` call is one-shot: connect + phx_join + push+phx_reply + close. Wraps async ChannelClient so click commands stay sync. URL discovery: `esr.ipc.url.discover_runtime_url(kind='handler')` — honors `ESR_HANDLER_HUB_URL` override and falls back to context-file ws endpoint.",
      "public_api": [
        "call_runtime(*, topic, event='cli_call', payload=None, override_url=None, timeout_sec=30.0) -> dict (py/src/esr/cli/runtime_bridge.py:45)",
        "RuntimeUnreachable (exception; carries endpoint URL) (py/src/esr/cli/runtime_bridge.py:15)"
      ],
      "internal": [
        "_call_runtime_async(topic, event, payload, url, timeout_sec) -> dict (py/src/esr/cli/runtime_bridge.py:21)"
      ],
      "error_semantics": {
        "connect_failure": "Wrapped as RuntimeUnreachable with URL (runtime_bridge.py:35)",
        "timeout": "TimeoutError from ChannelClient.call rewritten to RuntimeUnreachable (runtime_bridge.py:70)",
        "oserror": "Rewrapped as RuntimeUnreachable (runtime_bridge.py:74)"
      },
      "reply_envelope": "Phoenix phx_reply of form {status: 'ok'|'error', response: {...}}; the CLI's _response() helper in main.py:682 unwraps 'response' and raises RuntimeError when status != 'ok'. Dispatches that nest results under 'data' (e.g. cmd:run returns {'data': {'peer_ids': [...]}}) are peeled by the _submit_* helpers."
    },
    "cli_dispatch_topics": [
      "cli:run/<name> — _submit_cmd_run (main.py:692) → Elixir Registry.activate",
      "cli:stop/<name> — _submit_cmd_stop (main.py:708) → Registry.deactivate",
      "cli:trace — _submit_trace (main.py:734) → Telemetry.Buffer",
      "cli:debug/<action> — _submit_debug (main.py:747) → DebugOps (replay/inject/pause/resume)",
      "cli:drain — _submit_drain (main.py:755) → shutdown orchestrator",
      "cli:telemetry/<pattern> — _stream_telemetry (main.py:765) → Telemetry subscription",
      "cli:actors/<action> — _submit_actors (main.py:787) → ActorRegistry (list/tree/inspect/logs)",
      "cli:deadletter/<action> — _submit_deadletter (main.py:796) → DeadLetter (list/retry/flush)",
      "cli:workspace/register — workspace_add (main.py:1256) → live Workspace registry"
    ],
    "config_surface": {
      "endpoint_context_file": "~/.esr/context (YAML: {endpoint: ws://HOST:PORT/adapter_hub/socket})",
      "env_override": "ESR_CONTEXT (takes precedence over file)",
      "runtime_url_env": "ESR_HANDLER_HUB_URL (for cli → handler-hub RPC)",
      "adapters_yaml": "~/.esrd/default/adapters.yaml (written by adapter_add)",
      "workspaces_yaml": "~/.esrd/default/workspaces.yaml (written by workspace_add)",
      "compiled_artifacts": "~/.esrd/default/commands/.compiled/<name>.yaml (cmd_run/cmd_restart default lookup) or patterns/.compiled/<name>.yaml (cmd_install/cmd_compile default output)",
      "feishu_poll_chat_override": "FEISHU_TEST_CHAT_ID (auto-injected as poll_chat_id for feishu adapter)"
    }
  },
