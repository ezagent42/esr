# Local environment overrides for esrd. Copy to .env.local (gitignored).
# scripts/esrd.sh sources .env.local at startup if present.

# Bootstrap admin principal. Your IM user id (e.g. Feishu open_id
# "ou_xxxxxx"). On first esrd start this value is used to seed
# capabilities.yaml with a wildcard grant so you can actually run
# admin commands before any capabilities are configured.
#
# Also used by EsrWeb.ChannelChannel as the default principal_id when a
# cc_mcp client's tool_invoke arrives before its session_register.
#
# Future (see docs/futures/admin-principal-id-bind-cli.md): esrd will
# auto-generate an admin_principal_id at first boot; you'll then bind it
# to your IM id(s) via `esr admin bind-principal ...`. For now, set it
# here directly.
# export ESR_BOOTSTRAP_PRINCIPAL_ID=ou_your_feishu_open_id_here
